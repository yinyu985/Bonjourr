{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "short_name": "Bonjourr",
    "version": "3.0.0",
    "description": "__MSG_extensionDesc__",
    "author": "yinyu985 (forked from victrme/Bonjourr)",
    "default_locale": "en",
    "icons": {
        "16": "src/assets/favicons/favicon-16x16.png",
        "32": "src/assets/favicons/favicon-32x32.png",
        "48": "src/assets/favicons/favicon-48x48.png",
        "128": "src/assets/favicons/favicon-128x128.png"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "action": {
        "title": "__MSG_extensionName__"
    },
    "offline_enabled": true,
    "background": {
        "service_worker": "src/scripts/service-worker.js"
    },
    "permissions": [
        "storage",
        "unlimitedStorage",
        "favicon",
        "bookmarks"
    ],
    "optional_permissions": [
        "search"
    ],
    "host_permissions": [
        "https://*/*"
    ]
}
