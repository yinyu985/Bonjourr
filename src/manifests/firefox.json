{
    "manifest_version": 3,
    "name": "__MSG_extensionName__",
    "short_name": "Bonjourr",
    "version": "3.0.0",
    "description": "__MSG_extensionDesc__",
    "author": "yinyu985 (forked from victrme/Bonjourr)",
    "homepage_url": "https://github.com/yinyu985/Bonjourr",
    "default_locale": "en",
    "icons": {
        "16": "src/assets/favicons/favicon-16x16.png",
        "32": "src/assets/favicons/favicon-32x32.png",
        "48": "src/assets/favicons/favicon-48x48.png",
        "128": "src/assets/favicons/favicon-128x128.png"
    },
    "chrome_settings_overrides": {
        "homepage": "index.html"
    },
    "chrome_url_overrides": {
        "newtab": "index.html"
    },
    "action": {
        "default_icon": {
            "16": "src/assets/favicons/favicon-16x16.png",
            "32": "src/assets/favicons/favicon-32x32.png",
            "48": "src/assets/favicons/favicon-48x48.png",
            "128": "src/assets/favicons/favicon-128x128.png"
        },
        "default_title": "__MSG_extensionName__"
    },
    "background": {
        "scripts": [
            "src/scripts/service-worker.js"
        ]
    },
    "permissions": [
        "storage"
    ],
    "optional_permissions": [
        "bookmarks",
        "search"
    ],
    "browser_specific_settings": {
        "gecko": {
            "id": "{4f391a9e-8717-4ba6-a5b1-488a34931fcb}",
            "strict_min_version": "109.0"
        }
    }
}
